programa p11;
vars n, acc : entero;

entero siguiente(v : entero) {
    {
        regresa v + 1;
    }
};

inicio {
    n = 0;
    acc = 0;

    mientras (n < 5) haz {
        si (n != 3) {
            acc = acc + siguiente(n);
        } sino {
            acc = acc + 0;
        };
        n = n + 1;
    };

    escribe("acc=", acc);
} fin
